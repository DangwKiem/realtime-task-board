APP_ENV=development

DATABASE_URL=sqlite:///./taskboard.db
REDIS_URL=redis://localhost:6379/0

FRONTEND_ORIGINS=http://localhost:3000

SESSION_COOKIE_NAME=taskboard_session

# 30 phút không hoạt động thì session hết hạn.
SESSION_IDLE_TTL_SECONDS=1800

# Dù hoạt động liên tục, session tối đa 8 giờ.
SESSION_ABSOLUTE_TTL_SECONDS=28800

# Local đang dùng HTTP nên phải là false.
# Production HTTPS phải đổi thành true.
SESSION_SECURE=false